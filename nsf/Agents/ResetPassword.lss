'++LotusScript Development Environment:2:5:(Options):0:74
Option Public
Option Declare

'++LotusScript Development Environment:2:5:(Forward):0:1
Declare Sub Initialize

'++LotusScript Development Environment:2:5:(Declarations):0:10
' Agent: ResetPassword
' Purpose: Reset user password for both HTTP and ID Vault
' Requires valid verification token from VerifyAnswers agent
' Based on HCL Domino PwdResetSample.nsf pattern

'++LotusScript Development Environment:2:2:Initialize:17:10
Sub Initialize
    On Error GoTo ErrorHandler
    
    Dim session As New NotesSession
    Dim db As NotesDatabase
    Dim contextDoc As NotesDocument
    Dim view As NotesView
    Dim profileDoc As NotesDocument
    Dim jsonData As String
    Dim email As String
    Dim newPassword As String
    Dim token As String
    Dim httpResetSuccess As Boolean
    Dim vaultResetSuccess As Boolean
    
    Set db = session.CurrentDatabase
    Set contextDoc = session.DocumentContext
    
    ' Get POST data
    jsonData = contextDoc.GetItemValue("Request_Content")(0)
    email = ParseJsonValue(jsonData, "email")
    newPassword = ParseJsonValue(jsonData, "password")
    token = ParseJsonValue(jsonData, "token")
    
    ' Validate required fields
    If email = "" Or newPassword = "" Or token = "" Then
        Print "Content-Type: application/json"
        Print ""
        Print |{"success": false, "error": "Email, password, and token are required"}|
        Exit Sub
    End If
    
    ' Look up profile
    Set view = db.GetView("vwProfilesByEmail")
    Set profileDoc = view.GetDocumentByKey(LCase(email), True)
    
    If profileDoc Is Nothing Then
        Print "Content-Type: application/json"
        Print ""
        Print |{"success": false, "error": "Profile not found"}|
        Exit Sub
    End If
    
    ' Verify token
    Dim storedToken As String
    Dim tokenExpiry As Variant
    storedToken = profileDoc.GetItemValue("VerificationToken")(0)
    tokenExpiry = profileDoc.GetItemValue("TokenExpiry")(0)
    
    If storedToken = "" Or storedToken <> token Then
        Print "Content-Type: application/json"
        Print ""
        Print |{"success": false, "error": "Invalid or expired verification token"}|
        Exit Sub
    End If
    
    ' Check token expiry
    If IsDate(tokenExpiry) Then
        If Now > tokenExpiry Then
            Print "Content-Type: application/json"
            Print ""
            Print |{"success": false, "error": "Verification token has expired. Please start over."}|
            Exit Sub
        End If
    End If
    
    ' Get user's canonical name
    Dim userName As String
    userName = profileDoc.GetItemValue("UserName")(0)
    
    ' Reset HTTP Password
    httpResetSuccess = ResetHTTPPassword(session, userName, newPassword)
    
    ' Reset ID Vault Password
    vaultResetSuccess = ResetIDVaultPassword(session, db, userName, newPassword)
    
    ' Clear the verification token
    profileDoc.ReplaceItemValue "VerificationToken", ""
    profileDoc.ReplaceItemValue "TokenExpiry", ""
    profileDoc.ReplaceItemValue "LastPasswordReset", Now
    Call profileDoc.Save(True, False)
    
    ' Log the password reset
    Dim details As String
    details = "HTTP Reset: " & IIf(httpResetSuccess, "Success", "Failed") & ", "
    details = details & "Vault Reset: " & IIf(vaultResetSuccess, "Success", "N/A")
    Call LogAuditEvent(db, userName, email, "PASSWORD_RESET", details)
    
    ' Return result
    Print "Content-Type: application/json"
    Print ""
    Print |{"success": true, "httpReset": | & LCase(CStr(httpResetSuccess)) & |, "vaultReset": | & LCase(CStr(vaultResetSuccess)) & |}|
    
    Exit Sub
    
ErrorHandler:
    Print "Content-Type: application/json"
    Print ""
    Print |{"success": false, "error": "| & EscapeJson(Error$) & |"}|
End Sub

Function ResetHTTPPassword(session As NotesSession, userName As String, newPassword As String) As Boolean
    On Error GoTo ErrHandler
    
    Dim nab As NotesDatabase
    Dim view As NotesView
    Dim personDoc As NotesDocument
    
    ' Open Domino Directory
    Set nab = session.GetDatabase(session.CurrentDatabase.Server, "names.nsf", False)
    If nab Is Nothing Then
        ResetHTTPPassword = False
        Exit Function
    End If
    
    ' Find person document
    Set view = nab.GetView("($Users)")
    If view Is Nothing Then
        ResetHTTPPassword = False
        Exit Function
    End If
    
    Set personDoc = view.GetDocumentByKey(userName, True)
    If personDoc Is Nothing Then
        ' Try abbreviated name
        Dim nn As New NotesName(userName)
        Set personDoc = view.GetDocumentByKey(nn.Abbreviated, True)
    End If
    
    If personDoc Is Nothing Then
        ResetHTTPPassword = False
        Exit Function
    End If
    
    ' Hash the password using Domino's @Password
    Dim hashedPassword As Variant
    hashedPassword = Evaluate(|@Password("| & newPassword & |")|)
    
    ' Update the HTTPPassword field
    personDoc.ReplaceItemValue "HTTPPassword", hashedPassword(0)
    personDoc.ReplaceItemValue "HTTPPasswordChangeDate", Now
    
    Call personDoc.Save(True, False)
    
    ResetHTTPPassword = True
    Exit Function
    
ErrHandler:
    ResetHTTPPassword = False
End Function

Function ResetIDVaultPassword(session As NotesSession, db As NotesDatabase, userName As String, newPassword As String) As Boolean
    On Error GoTo ErrHandler
    
    ' Get ID Vault configuration
    Dim vaultServer As String
    Dim vaultPath As String
    
    vaultServer = GetConfigValue(db, "ID_VAULT_SERVER", "")
    vaultPath = GetConfigValue(db, "VAULT_DB_PATH", "IBM_ID_VAULT/vault.nsf")
    
    If vaultServer = "" Then
        ' ID Vault not configured
        ResetIDVaultPassword = False
        Exit Function
    End If
    
    ' Use NotesSession.ResetUserPassword method (available in Domino 9.0.1+)
    ' This requires the agent signer to have Password Reset Authority in the vault
    
    Dim reg As NotesRegistration
    Set reg = session.CreateRegistration
    reg.RegistrationServer = vaultServer
    reg.IDType = 1 ' ID_HIERARCHICAL
    
    ' Attempt to reset the password in ID Vault
    ' Note: This method requires proper vault configuration and permissions
    Call reg.ResetUserPassword(userName, newPassword, 0)
    
    ResetIDVaultPassword = True
    Exit Function
    
ErrHandler:
    ' ID Vault reset failed - this is expected if vault is not configured
    ' or if the agent signer doesn't have password reset authority
    ResetIDVaultPassword = False
End Function

Function GetConfigValue(db As NotesDatabase, key As String, defaultValue As Variant) As Variant
    On Error Resume Next
    Dim view As NotesView
    Dim doc As NotesDocument
    
    Set view = db.GetView("vwConfiguration")
    If view Is Nothing Then
        GetConfigValue = defaultValue
        Exit Function
    End If
    
    Set doc = view.GetDocumentByKey(key, True)
    If doc Is Nothing Then
        GetConfigValue = defaultValue
    Else
        GetConfigValue = doc.GetItemValue("Value")(0)
        If GetConfigValue = "" Then GetConfigValue = defaultValue
    End If
End Function

Function ParseJsonValue(jsonStr As String, key As String) As String
    On Error Resume Next
    Dim startPos As Integer, endPos As Integer
    Dim searchKey As String
    
    searchKey = """" & key & """"
    startPos = InStr(jsonStr, searchKey)
    If startPos = 0 Then Exit Function
    
    startPos = InStr(startPos, jsonStr, ":") + 1
    
    Do While Mid(jsonStr, startPos, 1) = " " Or Mid(jsonStr, startPos, 1) = """"
        startPos = startPos + 1
    Loop
    
    endPos = startPos
    Do While endPos <= Len(jsonStr)
        Dim c As String
        c = Mid(jsonStr, endPos, 1)
        If c = """" Or c = "," Or c = "}" Then Exit Do
        endPos = endPos + 1
    Loop
    
    ParseJsonValue = Mid(jsonStr, startPos, endPos - startPos)
End Function

Sub LogAuditEvent(db As NotesDatabase, userName As String, email As String, eventType As String, details As String)
    On Error Resume Next
    Dim doc As NotesDocument
    Set doc = db.CreateDocument
    doc.Form = "AuditLog"
    doc.UserName = userName
    doc.Email = email
    doc.EventType = eventType
    doc.Details = details
    doc.Timestamp = Now
    Call doc.Save(True, False)
End Sub

Function EscapeJson(inputStr As String) As String
    Dim result As String
    result = inputStr
    result = Replace(result, "\", "\\")
    result = Replace(result, """", "\""")
    result = Replace(result, Chr(10), "\n")
    result = Replace(result, Chr(13), "\r")
    result = Replace(result, Chr(9), "\t")
    EscapeJson = result
End Function

Function IIf(condition As Boolean, trueValue As Variant, falseValue As Variant) As Variant
    If condition Then
        IIf = trueValue
    Else
        IIf = falseValue
    End If
End Function
